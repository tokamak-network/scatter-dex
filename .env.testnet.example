# ═══════════════════════════════════════════════════════════
# zkScatter Testnet Deployment Configuration
# ═══════════════════════════════════════════════════════════
#
# Copy this file to .env and fill in real values:
#   cp .env.testnet.example .env
#
# Then deploy:
#   docker compose up -d shared-orderbook zk-relayer
#   docker compose --profile multi-relayer up -d  # for 2 relayers

# ── Network ───────────────────────────────────────────────
# Sepolia, Holesky, Titan Goerli, or any EVM testnet
RPC_URL=https://rpc.sepolia.org

# ── Contract Addresses (deploy first, then fill in) ──────
# Run: forge script script/DeployLocal.s.sol --rpc-url $RPC_URL --broadcast --private-key $DEPLOYER_KEY
COMMITMENT_POOL_ADDRESS=0x...
PRIVATE_SETTLEMENT_ADDRESS=0x...
FEE_VAULT_ADDRESS=0x...

# ── Deployer (only needed for initial deployment) ────────
# WARNING: Use a dedicated deployer key, not your main wallet
DEPLOYER_KEY=0x...

# ── Relayer A ────────────────────────────────────────────
# WARNING: Use a dedicated relayer key with minimal funds for gas
RELAYER_A_KEY=0x...
RELAYER_A_PUBLIC_URL=https://relayer-a.yourdomain.com

# ── Relayer B (optional, for multi-relayer mode) ─────────
RELAYER_B_KEY=0x...
RELAYER_B_PUBLIC_URL=https://relayer-b.yourdomain.com

# ── Frontend ─────────────────────────────────────────────
NEXT_PUBLIC_RPC_URL=https://rpc.sepolia.org
