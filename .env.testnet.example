# ═══════════════════════════════════════════════════════════
# zkScatter Testnet Deployment Configuration (Sepolia et al.)
# ═══════════════════════════════════════════════════════════
#
# TESTNET only. For LOCAL development use: ./scripts/dev.sh --mock
#
#   cp .env.testnet.example .env      # then fill in real values
#
# ── Two phases ──────────────────────────────────────────────
# 1. Deploy contracts (reads DEPLOYER_KEY below — no key on the CLI):
#      forge script script/DeploySepolia.s.sol:DeploySepolia \
#        --rpc-url "$RPC_URL" --broadcast
# 2. Run background services:
#      docker compose up -d shared-orderbook zk-relayer
#      docker compose --profile multi-relayer up -d   # for 2 relayers
#
# NOTE: DeploySepolia.s.sol (NOT DeployLocal) is the testnet script.
# DeployLocal is anvil-only — it deploys/mints mock tokens and tries to
# wrap 1100 ETH, which reverts on a real chain.

# ── Network ───────────────────────────────────────────────
# Sepolia, Holesky, or any EVM testnet.
RPC_URL=https://rpc.sepolia.org

# ── Deployer key (env-signing, non-interactive) ──────────
# DeploySepolia reads this directly, so the key never appears on the
# command line / shell history / process args. This file is gitignored
# (.env). NEVER commit it. Use a DEDICATED key funded with Sepolia ETH
# only — never your main / mainnet wallet.
# Alternative (more secure, but interactive password — not for AI runs):
#   omit DEPLOYER_KEY and pass  --account <keystore> --sender 0x...
DEPLOYER_KEY=0x...

# ── DeploySepolia required env (all REVERT if unset/zero) ─
# Real zk-X509 IdentityRegistry addresses — no mocks on testnet.
IDENTITY_REGISTRY=0x...            # User-CA   — gates deposits / claims
RELAYER_IDENTITY_REGISTRY=0x...    # Relayer-CA — gates RelayerRegistry.register()
# Proxy admin + treasury owners. Multisig recommended; may equal the
# deployer for a quick team testnet.
UPGRADE_OWNER=0x...
TREASURY_ADDRESS=0x...
# Canonical WETH9 already deployed on the target chain. Structural init
# param of PrivateSettlement, so required at deploy (other tokens are
# whitelisted AFTER deploy — see post-deploy below).
WETH_ADDRESS=0x...
# Optional: external sanctions oracle OR-combined into SanctionsList.
# SANCTIONS_EXTERNAL_ORACLE=0x...

# ── Contract addresses (fill in AFTER phase-1, from the deploy summary) ──
COMMITMENT_POOL_ADDRESS=0x...
PRIVATE_SETTLEMENT_ADDRESS=0x...
FEE_VAULT_ADDRESS=0x...

# ── Relayer A ────────────────────────────────────────────
# Dedicated relayer key, minimal gas funds. Registration is NOT done by
# the deploy script — the operator registers via the operators /register
# site (KYC -> zk-X509 proof -> admin approval -> register).
RELAYER_A_KEY=0x...
RELAYER_A_PUBLIC_URL=https://relayer-a.yourdomain.com

# ── Relayer B (optional, multi-relayer mode) ─────────────
RELAYER_B_KEY=0x...
RELAYER_B_PUBLIC_URL=https://relayer-b.yourdomain.com

# ── Frontend ─────────────────────────────────────────────
NEXT_PUBLIC_RPC_URL=https://rpc.sepolia.org
# Token list: once the on-chain whitelist getter ships
# (feat/token-whitelist-getter + feat/onchain-token-list), the frontend
# reads whitelisted tokens directly from the chain and NEXT_PUBLIC_TOKENS
# is only a metadata/label fallback. Until then it is the source of truth.
# NEXT_PUBLIC_TOKENS=0xWETH:WETH:18,0xUSDC:USDC:6,0xTON:TON:18

# ── Post-deploy (owner = deployer; do these AFTER phase-1) ────────────
# 1. Whitelist real tokens on BOTH boundary contracts (no mock tokens):
#      cast send $COMMITMENT_POOL_ADDRESS    'setTokenWhitelist(address,bool)' <TOKEN> true \
#        --rpc-url $RPC_URL --account deployer-sepolia
#      cast send $PRIVATE_SETTLEMENT_ADDRESS 'setTokenWhitelist(address,bool)' <TOKEN> true \
#        --rpc-url $RPC_URL --account deployer-sepolia
# 2. Register the relayer via the operators /register site (real zk-X509
#    + admin approval required; reverts NotVerified until then).
