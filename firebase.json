{
  "hosting": [
    {
      "target": "hub",
      "public": "apps/hub/out",
      "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
      "cleanUrls": true,
      "trailingSlash": false,
      "headers": [
        {
          "source": "**/*.@(js|css|woff2|woff|ttf|svg|png|jpg|jpeg|webp|ico)",
          "headers": [
            { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
          ]
        },
        {
          "source": "**/*.@(html|json)",
          "headers": [
            { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
          ]
        }
      ]
    },
    {
      "target": "docs",
      "public": "apps/docs/out",
      "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
      "cleanUrls": true,
      "trailingSlash": false,
      "redirects": [
        { "source": "/", "destination": "/docs/introduction", "type": 301 },
        { "source": "/introduction", "destination": "/docs/introduction", "type": 301 },
        { "source": "/installation", "destination": "/docs/installation", "type": 301 },
        { "source": "/quickstart", "destination": "/docs/quickstart", "type": 301 },
        { "source": "/faq", "destination": "/docs/faq", "type": 301 },
        { "source": "/concepts/:path*", "destination": "/docs/concepts/:path*", "type": 301 },
        { "source": "/guides/:path*", "destination": "/docs/guides/:path*", "type": 301 },
        { "source": "/protocol/:path*", "destination": "/docs/protocol/:path*", "type": 301 },
        { "source": "/operate/:path*", "destination": "/docs/operate/:path*", "type": 301 },
        { "source": "/api/:path*", "destination": "/sdk/api/:path*", "type": 301 },
        { "source": "/rest/:path*", "destination": "/sdk/rest/:path*", "type": 301 }
      ],
      "headers": [
        {
          "source": "**/*.@(js|css|woff2|woff|ttf|svg|png|jpg|jpeg|webp|ico)",
          "headers": [
            { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
          ]
        },
        {
          "source": "**/*.@(html|json)",
          "headers": [
            { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
          ]
        }
      ]
    },
    {
      "target": "pro",
      "public": "apps/pro/out",
      "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
      "cleanUrls": true,
      "trailingSlash": false,
      "headers": [
        {
          "source": "**/*.@(js|css|woff2|woff|ttf|svg|png|jpg|jpeg|webp|ico)",
          "headers": [
            { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
          ]
        },
        {
          "source": "**/*.@(html|json)",
          "headers": [
            { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
          ]
        }
      ]
    }
  ]
}
