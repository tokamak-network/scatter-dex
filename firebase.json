{
  "_csp_notes": [
    "Strict CSP — rejects `unsafe-eval` in `script-src` so an XSS",
    "escalation cannot pivot into RCE. Currently applied to the two",
    "deployed targets (hub, pay). Other targets (docs, pro, relayer)",
    "stay header-stripped until they're re-enabled — when that happens,",
    "copy the matching CSP block from hub (static, no ZK) or pay (ZK",
    "in WebWorkers, wagmi RPC, relayer + shared-orderbook fetch).",
    "",
    "apps/pay moved snarkjs into WebWorkers (`apps/pay/app/workers/*.worker.ts`),",
    "so the main thread no longer needs eval. If a future change",
    "reintroduces a main-thread snarkjs / Function() call site, this",
    "header will flag it via a console CSP violation — fix the call",
    "site, don't loosen the header.",
    "",
    "connect-src is intentionally permissive (`https: wss:`) because RPC",
    "and relayer hosts are per-deployment env vars. Tighten to an",
    "explicit allow-list once we ship a stable per-environment config."
  ],
  "hosting": [
    {
      "target": "hub",
      "public": "apps/hub/out",
      "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
      "cleanUrls": true,
      "trailingSlash": false,
      "headers": [
        {
          "source": "**",
          "headers": [
            { "key": "Content-Security-Policy", "value": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self' data:; connect-src 'self'; frame-ancestors 'none'; base-uri 'self'; form-action 'self'; object-src 'none'" },
            { "key": "X-Content-Type-Options", "value": "nosniff" },
            { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
          ]
        },
        {
          "source": "**/*.@(js|css|woff2|woff|ttf|svg|png|jpg|jpeg|webp|ico)",
          "headers": [
            { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
          ]
        },
        {
          "source": "**/*.@(html|json)",
          "headers": [
            { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
          ]
        }
      ]
    },
    {
      "target": "docs",
      "public": "apps/docs/out",
      "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
      "cleanUrls": true,
      "trailingSlash": false,
      "redirects": [
        { "source": "/", "destination": "/docs/introduction", "type": 301 },
        { "source": "/introduction", "destination": "/docs/introduction", "type": 301 },
        { "source": "/installation", "destination": "/docs/installation", "type": 301 },
        { "source": "/quickstart", "destination": "/docs/quickstart", "type": 301 },
        { "source": "/faq", "destination": "/docs/faq", "type": 301 },
        { "source": "/concepts/:path*", "destination": "/docs/concepts/:path*", "type": 301 },
        { "source": "/guides/:path*", "destination": "/docs/guides/:path*", "type": 301 },
        { "source": "/protocol/:path*", "destination": "/docs/protocol/:path*", "type": 301 },
        { "source": "/operate/:path*", "destination": "/docs/operate/:path*", "type": 301 },
        { "source": "/api/:path*", "destination": "/sdk/api/:path*", "type": 301 },
        { "source": "/rest/:path*", "destination": "/sdk/rest/:path*", "type": 301 }
      ],
      "headers": [
        {
          "source": "**/*.@(js|css|woff2|woff|ttf|svg|png|jpg|jpeg|webp|ico)",
          "headers": [
            { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
          ]
        },
        {
          "source": "**/*.@(html|json)",
          "headers": [
            { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
          ]
        }
      ]
    },
    {
      "target": "pro",
      "public": "apps/pro/out",
      "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
      "cleanUrls": true,
      "trailingSlash": false,
      "headers": [
        {
          "source": "**/*.@(js|css|woff2|woff|ttf|svg|png|jpg|jpeg|webp|ico)",
          "headers": [
            { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
          ]
        },
        {
          "source": "**/*.@(html|json)",
          "headers": [
            { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
          ]
        }
      ]
    },
    {
      "target": "pay",
      "public": "apps/pay/out",
      "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
      "cleanUrls": true,
      "trailingSlash": false,
      "headers": [
        {
          "source": "**",
          "headers": [
            { "key": "Content-Security-Policy", "value": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; font-src 'self' data:; worker-src 'self' blob:; connect-src 'self' https: wss:; frame-ancestors 'none'; base-uri 'self'; form-action 'self'; object-src 'none'" },
            { "key": "X-Content-Type-Options", "value": "nosniff" },
            { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
          ]
        },
        {
          "source": "**/*.@(js|css|woff2|woff|ttf|svg|png|jpg|jpeg|webp|ico)",
          "headers": [
            { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
          ]
        },
        {
          "source": "**/*.@(html|json)",
          "headers": [
            { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
          ]
        }
      ]
    },
    {
      "target": "relayer",
      "public": "apps/operators/out",
      "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
      "cleanUrls": true,
      "trailingSlash": false,
      "headers": [
        {
          "source": "**/*.@(js|css|woff2|woff|ttf|svg|png|jpg|jpeg|webp|ico)",
          "headers": [
            { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
          ]
        },
        {
          "source": "**/*.@(html|json)",
          "headers": [
            { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
          ]
        }
      ]
    }
  ]
}
