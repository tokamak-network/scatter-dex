# deploy/gcp/deploy.env — copy to deploy.env (gitignored) and fill in.
# Consumed by vm-create.sh.

# Chain RPC. Free options:
#   publicnode:   https://ethereum-sepolia.publicnode.com
#   alchemy:      https://eth-sepolia.g.alchemy.com/v2/<API_KEY>
RPC_URL=https://ethereum-sepolia.publicnode.com

# Deployed contracts (Sepolia).
COMMITMENT_POOL_ADDRESS=0x...
PRIVATE_SETTLEMENT_ADDRESS=0x...

# Comma-separated frontend origins allowed by the relayer's CORS.
CORS_ORIGINS=https://pay.zkscatter.io,https://pro.zkscatter.io,http://localhost:3000

# Image tag to deploy. 'latest' is fine for first boot; pin to a commit
# SHA later so re-deploys are reproducible.
IMAGE_TAG=latest

# Leave blank for IP-only / HTTP testing.
# Set to a real apex domain once orderbook.<DOMAIN> + zk.<DOMAIN> point here.
DOMAIN=
ACME_EMAIL=
