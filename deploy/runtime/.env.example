# deploy/runtime/.env — copy to .env and fill in.
# Loaded by docker compose automatically.

# ─── Image references ───────────────────────────────────────────────
# Pre-built images. For Artifact Registry, the form is:
#   us-central1-docker.pkg.dev/zkscatter/zkscatter/shared-orderbook
# These must point at images already pushed to the registry; this compose
# file does not contain `build:` blocks.
SHARED_ORDERBOOK_IMAGE=
ZK_RELAYER_IMAGE=
IMAGE_TAG=latest

# ─── Public-facing ports ────────────────────────────────────────────
# Direct-port mode (no Caddy / no TLS). Useful for IP-only testing.
SHARED_ORDERBOOK_PORT=4000
ZK_RELAYER_PORT=3002

# ─── TLS mode (only used by compose.tls.yml) ───────────────────────
# Leave blank to skip TLS. Set to a real domain to enable Caddy auto-TLS.
# Caddy will obtain Let's Encrypt certs at startup.
DOMAIN=
ACME_EMAIL=

# ─── shared-orderbook ──────────────────────────────────────────────
SHARED_ORDERBOOK_DB_PATH=/data/shared-orderbook.db
# SIWE admin allowlist — comma-separated wallet addresses that may sign in to
# the admin KYC review (wallet-signature auth). Leave blank to keep the SIWE
# challenge/session endpoints unmounted (404); the other admin-gated routes
# then return 503 (no auth configured). These are PUBLIC addresses; on GCP the
# value comes from instance metadata `admin-addresses`, not from git.
ADMIN_ADDRESSES=
# Optional static bearer token for CI / verify-stats (legacy path; the admin
# app itself uses SIWE, not this). On GCP, injected from Secret Manager
# `admin-token`. Leave blank to disable the static path.
ADMIN_TOKEN=

# ─── chain selection (verifier + commitment-indexer) ───────────────
# Single-chain fallback chainId for both sidecars. Defaults to Sepolia.
CHAIN_ID=11155111
# Multi-network: set these JSON arrays to run one loop PER chain (they override
# the single-chain CHAIN_ID/RPC_URL/address fallbacks above). Leave blank for
# single-chain.
#   CHAINS='[{"chainId":11155111,"rpcUrl":"https://…","settlementAddress":"0x…"}]'
#   COMMITMENT_CHAINS='[{"chainId":11155111,"rpcUrl":"https://…","commitmentPoolAddress":"0x…","deployBlock":11008264}]'
CHAINS=
COMMITMENT_CHAINS=

# ─── commitment-indexer ────────────────────────────────────────────
# Scans CommitmentInserted from the pool deploy block into the shared DB so
# GET /api/commitments can serve Merkle leaves. Reuses RPC_URL +
# COMMITMENT_POOL_ADDRESS (below). Set the deploy block from the ledger
# (contracts/deployments/<chainId>.json "deployBlock") so it doesn't scan from
# genesis. The tuning vars have sane defaults — override only if needed.
COMMITMENT_DEPLOY_BLOCK=
# COMMITMENT_POLL_INTERVAL_SEC=30
# COMMITMENT_BLOCK_SAFETY_MARGIN=6
# COMMITMENT_INDEX_BLOCK_RANGE=50000

# ─── zk-relayer ────────────────────────────────────────────────────
RPC_URL=
COMMITMENT_POOL_ADDRESS=
PRIVATE_SETTLEMENT_ADDRESS=
RELAYER_FEE=30
# Comma-separated origins for CORS. Production: list real frontends.
CORS_ORIGINS=
# Path on the host that holds circuit build artifacts (zkey, wasm, vkey).
# Must contain the same layout that circuits/build/ uses in the repo.
CIRCUITS_BUILD_DIR=/opt/zkscatter/circuits/build
# Relayer signing key file. Mounted as a docker secret.
RELAYER_KEY_FILE=/opt/zkscatter/secrets/relayer.key
