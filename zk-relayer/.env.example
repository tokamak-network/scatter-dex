# ── Network ──────────────────────────────────────────────
RPC_URL=http://localhost:8545

# ── Relayer Key ──────────────────────────────────────────
# WARNING: Never commit real private keys. For local dev with Anvil,
# use well-known test keys (see: https://book.getfoundry.sh/reference/anvil/)
RELAYER_PRIVATE_KEY=

# ── Contract Addresses ───────────────────────────────────
# Set these to the deployed contract addresses for your environment.
COMMITMENT_POOL_ADDRESS=
PRIVATE_SETTLEMENT_ADDRESS=
FEE_VAULT_ADDRESS=

# ── Token List (for vault dashboard) ────────────────────
# Format: address:symbol:decimals,address:symbol:decimals
TOKEN_LIST=

# ── Server ───────────────────────────────────────────────
PORT=3002
RELAYER_FEE=30
DB_PATH=./zk-relayer.db
CORS_ORIGINS=http://localhost:3000,http://localhost:3002

# ── Admin API (optional) ────────────────────────────────
# Generate a strong random key: openssl rand -hex 32
# ADMIN_API_KEY=

# ── Sanctions (optional) ────────────────────────────────
# Path to JSON file with sanctioned EdDSA pubKeys.
# Format: [{ "pubKeyAx": "123...", "pubKeyAy": "456..." }, ...]
# Can also be managed at runtime via admin API.
# SANCTIONS_PUBKEY_LIST=./sanctions.json

# ── Shared Orderbook (optional) ─────────────────────────
# SHARED_ORDERBOOK_URL=
# RELAYER_PUBLIC_URL=
# RELAYER_NAME=
