# ── Network ──────────────────────────────────────────────
RPC_URL=http://localhost:8545

# ── Relayer Key ──────────────────────────────────────────
# WARNING: Never commit real private keys. For local dev with Anvil,
# use well-known test keys (see: https://book.getfoundry.sh/reference/anvil/)
RELAYER_PRIVATE_KEY=0x_YOUR_RELAYER_PRIVATE_KEY_HERE

# ── Contract Addresses ───────────────────────────────────
COMMITMENT_POOL_ADDRESS=0x...
PRIVATE_SETTLEMENT_ADDRESS=0x...
FEE_VAULT_ADDRESS=0x...

# ── Server ───────────────────────────────────────────────
PORT=3002
RELAYER_FEE=30
DB_PATH=./zk-relayer.db
CORS_ORIGINS=http://localhost:3000,http://localhost:3002

# ── Admin API (optional) ────────────────────────────────
# Generate a strong random key: openssl rand -hex 32
# ADMIN_API_KEY=
