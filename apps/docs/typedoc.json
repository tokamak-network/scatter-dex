{
  "$schema": "https://typedoc.org/schema.json",
  "entryPoints": [
    "../../packages/sdk/src/core/index.ts",
    "../../packages/sdk/src/contracts/index.ts",
    "../../packages/sdk/src/zk/index.ts",
    "../../packages/sdk/src/relayer/index.ts",
    "../../packages/sdk/src/orderbook/index.ts",
    "../../packages/sdk/src/notes/index.ts",
    "../../packages/sdk/src/react/index.ts"
  ],
  "tsconfig": "../../packages/sdk/tsconfig.json",
  "out": "../../developers/sdk/api",
  "plugin": ["typedoc-plugin-markdown"],
  "fileExtension": ".mdx",
  "entryFileName": "index",
  "readme": "none",
  "githubPages": false,
  "hideBreadcrumbs": true,
  "hidePageHeader": true,
  "useCodeBlocks": true,
  "expandObjects": true,
  "parametersFormat": "table",
  "propertiesFormat": "table",
  "enumMembersFormat": "table",
  "indexFormat": "table",
  "excludePrivate": true,
  "excludeInternal": true,
  "excludeProtected": false,
  "skipErrorChecking": true,
  "sort": ["source-order"],
  "name": "@zkscatter/sdk",
  "navigationLinks": {},
  "disableSources": true
}
