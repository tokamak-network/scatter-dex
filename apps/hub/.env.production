# Production env for the hub Firebase deploy. Mirrors the fallbacks
# in `apps/hub/app/lib/apps.ts` (both `APP_URLS` and `DOCS_URL`), but
# committing them here makes the build deterministic even on CI
# runners that don't inject NEXT_PUBLIC_* explicitly — the fallbacks
# are belt-and-braces.
#
# When a target re-enables, also flip its `comingSoon: true` in the
# same file so the nav stops dimming it. Until then the URL below is
# correct but the link is gated behind the flag.
NEXT_PUBLIC_PRO_URL=https://zkscatter-pro.web.app
NEXT_PUBLIC_PAY_URL=https://zkscatter-pay.web.app
NEXT_PUBLIC_DROP_URL=https://zkscatter-drop.web.app
NEXT_PUBLIC_RELAYER_URL=https://zkscatter-relayer.web.app
NEXT_PUBLIC_DOCS_URL=https://zkscatter-docs.web.app
