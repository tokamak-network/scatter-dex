{
  "name": "@zkscatter/sdk",
  "version": "0.0.1",
  "private": true,
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "description": "Typed TypeScript client for the zkScatter core (contracts + ZK + relayer + shared orderbook).",
  "type": "module",
  "sideEffects": false,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./core": "./src/core/index.ts",
    "./react": "./src/react/index.ts",
    "./zk": "./src/zk/index.ts",
    "./claim": "./src/claim/index.ts",
    "./relayer": "./src/relayer/index.ts",
    "./orderbook": "./src/orderbook/index.ts",
    "./contracts": "./src/contracts/index.ts",
    "./contracts/eip5792": "./src/contracts/eip5792.ts",
    "./notes": "./src/notes/index.ts",
    "./storage": "./src/storage/index.ts",
    "./util": "./src/util/index.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@noble/curves": "^2.0.1",
    "@noble/hashes": "^2.0.1",
    "circomlibjs": "^0.1.7",
    "ethers": "^6.16.0",
    "snarkjs": "^0.7.6"
  },
  "peerDependencies": {
    "react": "^19"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "fake-indexeddb": "^6.2.5",
    "react": "^19",
    "typescript": "^5",
    "vitest": "^3.2.4"
  }
}
