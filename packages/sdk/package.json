{
  "name": "@zkscatter/sdk",
  "version": "0.0.1",
  "private": true,
  "description": "Typed TypeScript client for the zkScatter core (contracts + ZK + relayer + shared orderbook).",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./core": "./src/core/index.ts",
    "./react": "./src/react/index.ts",
    "./zk": "./src/zk/index.ts",
    "./relayer": "./src/relayer/index.ts",
    "./orderbook": "./src/orderbook/index.ts",
    "./contracts": "./src/contracts/index.ts",
    "./notes": "./src/notes/index.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@noble/curves": "^2.0.1",
    "@noble/hashes": "^2.0.1",
    "circomlibjs": "^0.1.7",
    "ethers": "^6.16.0",
    "snarkjs": "^0.7.6"
  },
  "peerDependencies": {
    "react": "^19"
  },
  "peerDependenciesMeta": {
    "react": { "optional": true }
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "react": "^19",
    "typescript": "^5"
  }
}
