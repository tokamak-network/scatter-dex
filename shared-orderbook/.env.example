# ── Server ───────────────────────────────────────────────
PORT=4000
DB_PATH=./shared-orderbook.db

# ── CORS ─────────────────────────────────────────────────
# Comma-separated list of allowed origins. Set explicit origins for production.
# Default (if unset): http://localhost:3000,http://localhost:3002,http://localhost:3003
# CORS_ORIGINS=https://app.yourdomain.com

# ── Rate Limiting ────────────────────────────────────────
# WRITE_RATE_LIMIT=60
# READ_RATE_LIMIT=300

# ── Webhook ──────────────────────────────────────────────
# WEBHOOK_TIMEOUT=5000

# ── Order Limits ─────────────────────────────────────────
# MAX_ORDERS_PER_RELAYER=1000
# MAX_ORDERS=50000
