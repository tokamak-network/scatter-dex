# Learn more https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files

# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files
.env*.local

# typescript
*.tsbuildinfo

# generated native folders
/ios
/android

# Legacy WebView ZK engine bundle (Phase C-5 removed the WebView path).
# Kept here so a stale local checkout's `.build/` doesn't get committed.
.build/

# Legacy WebView circuit binaries — `assets/zk-native/*.zkey` is tracked
# (the APK ships them); these `assets/zk/` paths are leftovers from the
# pre-C4 WebView pipeline and should never be re-added.
assets/zk/*.wasm
assets/zk/*.zkey

# `src/config/fork-contracts.json` is tracked with a default-empty `{}`
# so Metro's static `require()` resolves in a fresh clone. scripts/dev.sh
# and scripts/dev-fork.sh overwrite it on each deploy; do NOT commit
# deployment-specific addresses back — the file's diff should stay as
# `{}` on feature branches. (`git update-index --skip-worktree` on the
# file is a useful local guard.)
