target/
build/
*.jar

# Build inputs: duplicates of circuits/build/ — copy before `mopro build`
test-vectors/circom/authorize_final.zkey
test-vectors/circom/authorize.wasm

# Generated static lib (~40MB per arch). Regenerate with `mopro build`.
MoproReactNativeBindings/MoproFfiFramework.xcframework/*/libnative_prover.a

# Android native lib — build with
# `cargo build --release --target aarch64-linux-android` (NDK toolchain
# wired via env vars; see README) and copy the resulting `libnative_prover.so`
# into `MoproReactNativeBindings/android/src/main/jniLibs/arm64-v8a/`.
MoproReactNativeBindings/android/src/main/jniLibs/

# Android Gradle / CMake intermediate output.
MoproReactNativeBindings/android/.cxx/
MoproReactNativeBindings/android/build/

# `bob build` output — Metro consumes the regenerated TS at `src/index.tsx`
# directly (see the patched `package.json#main`), so committing this just
# bloats diffs.
MoproReactNativeBindings/lib/
