{
  "expo": {
    "name": "ScatterDEX",
    "slug": "scatter-dex-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "scheme": "scatterdex",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0f1e"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "io.scatterdex.mobile",
      "infoPlist": {
        "NSFaceIDUsageDescription": "Authenticate to access your private keys"
      }
    },
    "android": {
      "package": "io.scatterdex.mobile",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0a0f1e"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store"
    ],
    "extra": {
      "RPC_URL": "https://rpc.thanos-sepolia.tokamak.network",
      "CHAIN_ID": "111551119090",
      "RELAYER_URL": "http://localhost:4000",
      "WALLETCONNECT_PROJECT_ID": "",
      "eas": {
        "projectId": ""
      }
    }
  }
}
