# Settlement contract address (deployed ScatterSettlement)
NEXT_PUBLIC_SETTLEMENT_ADDRESS=0x...

# RelayerRegistry contract address
NEXT_PUBLIC_RELAYER_REGISTRY_ADDRESS=0x...

# VaultSkills (EIP-7702 delegation target) contract address
NEXT_PUBLIC_VAULTSKILLS_ADDRESS=0x...

# WETH contract address (used to auto-generate ETH native entry in token list)
NEXT_PUBLIC_WETH_ADDRESS=0xC02aaA39b223FE8D0A0e5C4F27eAD9083C756Cc2

# JSON-RPC endpoint (defaults to http://localhost:8545)
NEXT_PUBLIC_RPC_URL=http://localhost:8545

# Expected chain ID (defaults to 31337 = Anvil/Hardhat localhost)
NEXT_PUBLIC_CHAIN_ID=31337

# Token addresses (comma-separated: address:symbol:decimals)
# Do NOT include ETH sentinel here — ETH is auto-derived from NEXT_PUBLIC_WETH_ADDRESS.
# Only list ERC-20 tokens (WETH, USDC, etc.).
NEXT_PUBLIC_TOKENS=0xC02aaA39b223FE8D0A0e5C4F27eAD9083C756Cc2:WETH:18,0xA0b86991c6218b36c1d19D4a2e9Eb0cE3606eB48:USDC:6
