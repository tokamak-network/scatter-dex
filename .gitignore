# Next.js
.next/

# Foundry
contracts/broadcast/
contracts/cache/
contracts/foundry.lock

# Dev logs
.dev-logs/

# Environment files
.env
.env.local
*.env.local

# Database files
*.db
*.db-shm
*.db-wal

# Circuit build artifacts (regenerated by scripts/build.sh)
circuits/build/
circuits/node_modules/

# ZK artifacts in frontend (copied by circuit build)
frontend/public/zk/

# Pay's authorize circuit assets are mirrored from apps/pro/public/zk
# at predev / prebuild time (apps/pay/scripts/sync-zk-assets.mjs) to
# avoid duplicating 24 MB of binaries in git.
apps/pay/public/zk/

# Generated Groth16 verifier contracts. Each phase-2 setup uses a fresh
# random beacon, so the embedded vkey constants change per build. Committing
# them would let the tracked copy disagree with the locally-built zkey →
# InvalidProof() at runtime. Hand-written verifiers (interfaces,
# BatchAuthorizeVerifier) stay tracked.
contracts/src/zk/AuthorizeVerifier.sol
contracts/src/zk/AuthorizeVerifier_64.sol
contracts/src/zk/AuthorizeVerifier_128.sol
contracts/src/zk/CancelVerifier.sol
contracts/src/zk/ClaimVerifier.sol
contracts/src/zk/ClaimVerifier_64.sol
contracts/src/zk/ClaimVerifier_128.sol
contracts/src/zk/DepositVerifier.sol
contracts/src/zk/WithdrawVerifier.sol
contracts/src/zk/SettleVerifier.sol

# zk-relayer build artifacts
zk-relayer/dist/
shared-orderbook/dist/

# Auto-generated SDK reference (TypeDoc output) produced by
# `cd apps/docs && npm run api`. Committing it drifts across Node
# versions / TypeScript installs (TypeDoc categorises some internal
# re-exports differently between Node 20 / 22 / 24, e.g. the noble
# `bytesToNumberBE` re-export), so we regenerate it on every build
# instead. The OpenAPI yaml (`apps/docs/public/openapi/relayer.yaml`)
# stays committed because its output is deterministic.
developers/sdk/api/

# Node modules
node_modules/

# Lock files (each package manages its own)
# circuits/package-lock.json is excluded since circuits/ has its own npm setup

# Misc
frontend/1.json
relayer/dist/
.e2e-logs/

# Docker volumes
orderbook-data/
relayer-a-data/
relayer-b-data/
.claude/

# Firebase Hosting — local CLI cache and per-app static export output
.firebase/
apps/*/out/
apps/*/tsconfig.tsbuildinfo
